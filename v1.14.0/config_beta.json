    "auto_detect_interface": true,
    "final": "runaway",
    "default_domain_resolver": {
      "server": "Local-DNS"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "Local-DNS",
        "type": "tls",
        "domain_resolver": "Local-DNS-Resolver",
        "server_port": 853,
        "server": "223.5.5.5"
      },
      {
        "tag": "Local-DNS-Resolver",
        "type": "udp",
        "server_port": 53,
        "server": "223.5.5.5"
      },
      {
        "tag": "Remote-DNS",
        "type": "tls",
        "detour": "Proxy",
        "domain_resolver": "Remote-DNS-Resolver",
        "server_port": 853,
        "server": "8.8.8.8"
      },
      {
        "tag": "Remote-DNS-Resolver",
        "type": "udp",
        "detour": "Proxy",
        "server_port": 53,
        "server": "8.8.8.8"
      }
    ],
    "rules": [
      {
        "action": "route",
        "clash_mode": "direct",
        "server": "Local-DNS"
      },
      {
        "action": "route",
        "clash_mode": "global",
        "server": "Remote-DNS"
      },
      {
        "action": "route",
        "domain_suffix": ["pentaplus.cn"],
        "server": "Remote-DNS"
      },
      {
        "action": "route",
        "rule_set": ["GeoSite-CN"],
        "server": "Local-DNS"
      },
      {
        "action": "route",
        "rule_set": ["GeoLocation-!CN"],
        "server": "Remote-DNS"
      },
      {
        "action": "evaluate",
        "server": "Remote-DNS"
      },
      {
        "match_response": true,
        "rule_set": ["GeoIP-CN"],
        "action": "route",
        "server": "Local-DNS"
      },
      {
        "action": "respond"
      }
    ],
    "disable_cache": false,
    "disable_expire": false,
    "optimistic": true,
    "final": "Remote-DNS"
  }
}
